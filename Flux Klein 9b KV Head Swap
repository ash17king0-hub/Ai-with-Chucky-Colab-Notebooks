        "# @title 2. 🎭 Head Swap Execution\n",
        "import subprocess\n",
        "import time\n",
        "import sys\n",
        "import json\n",
        "import urllib.request\n",
        "import urllib.error\n",
        "import os\n",
        "import shutil\n",
        "from google.colab import files\n",
        "from IPython.display import Image, display, clear_output\n",
        "\n",
        "class C:\n",
        "    G = '\\033[1;32m'\n",
        "    C = '\\033[1;36m'\n",
        "    Y = '\\033[1;33m'\n",
        "    R = '\\033[1;31m'\n",
        "    P = '\\033[1;35m'\n",
        "    X = '\\033[0m'\n",
        "\n",
        "os.chdir('/content')\n",
        "\n",
        "print(f\"{C.C}══════════════════════════════════════════════════════════════════════{C.X}\")\n",
        "print(f\"{C.P}                   🎭 FACE SWAP: IMAGE UPLOAD 🎭{C.X}\")\n",
        "print(f\"{C.C}══════════════════════════════════════════════════════════════════════{C.X}\\n\")\n",
        "\n",
        "print(f\"{C.Y}📸 STEP 1: Upload your BASE IMAGE (The original body/scene you want to keep){C.X}\")\n",
        "base_upload = files.upload()\n",
        "base_filename = list(base_upload.keys())[0]\n",
        "\n",
        "print(f\"\\n{C.Y}👤 STEP 2: Upload your TARGET FACE (The new face you want to swap into the base image){C.X}\")\n",
        "face_upload = files.upload()\n",
        "face_filename = list(face_upload.keys())[0]\n",
        "\n",
        "clear_output()\n",
        "print(f\"{C.G}✅ Images captured!{C.X} Base: [{base_filename}] | Face: [{face_filename}]\\n\")\n",
        "\n",
        "os.chdir('/content/ComfyUI')\n",
        "os.makedirs('input', exist_ok=True)\n",
        "shutil.move(f'/content/{base_filename}', f'input/{base_filename}')\n",
        "shutil.move(f'/content/{face_filename}', f'input/{face_filename}')\n",
        "\n",
        "print(f\"{C.C}📥 Fetching AI Workflow...{C.X}\")\n",
        "!pip install gdown -q\n",
        "!gdown \"14TbxBBpuieGpZt5KEusZq1I7wz-cuRgT\" -O workflow_api.json -q\n",
        "\n",
        "print(f\"{C.C}⚙️ Igniting AI Server in the background (Low VRAM Mode)...{C.X}\")\n",
        "log_file = open(\"server.log\", \"w\")\n",
        "server_process = subprocess.Popen(\n",
        "    [\"python\", \"main.py\", \"--lowvram\"],\n",
        "    stdout=log_file,\n",
        "    stderr=log_file\n",
        ")\n",
        "\n",
        "def wait_for_server(timeout=240):\n",
        "    print(f\"{C.Y}⏳ Waking up models (this usually takes 1-2 minutes)...{C.X}\")\n",
        "    start_time = time.time()\n",
        "    while time.time() - start_time < timeout:\n",
        "        try:\n",
        "            with urllib.request.urlopen(\"http://127.0.0.1:8188/system_stats\") as response:\n",
        "                if response.status == 200: return True\n",
        "        except Exception:\n",
        "            time.sleep(2)\n",
        "    return False\n",
        "\n",
        "if not wait_for_server():\n",
        "    print(f\"{C.R}❌ Error: AI server failed to start.{C.X}\")\n",
        "    server_process.kill()\n",
        "    raise SystemExit(\"Server startup failed. Check server.log\")\n",
        "\n",
        "print(f\"{C.G}✅ System Online!{C.X}\")\n",
        "\n",
        "with open(\"workflow_api.json\", \"r\", encoding=\"utf-8\") as f:\n",
        "    prompt = json.load(f)\n",
        "\n",
        "prompt[\"76\"][\"inputs\"][\"image\"] = base_filename\n",
        "prompt[\"81\"][\"inputs\"][\"image\"] = face_filename\n",
        "\n",
        "def queue_prompt(prompt):\n",
        "    req = urllib.request.Request(\"http://127.0.0.1:8188/prompt\", data=json.dumps({\"prompt\": prompt}).encode('utf-8'))\n",
        "    return json.loads(urllib.request.urlopen(req).read())\n",
        "\n",
        "def get_history(prompt_id):\n",
        "    return json.loads(urllib.request.urlopen(f\"http://127.0.0.1:8188/history/{prompt_id}\").read())\n",
        "\n",
        "print(f\"{C.P}🚀 Injecting Payload into AI Server...{C.X}\")\n",
        "try:\n",
        "    response = queue_prompt(prompt)\n",
        "    prompt_id = response['prompt_id']\n",
        "    print(f\"{C.G}✅ Workflow active!{C.X} Tracking ID: {prompt_id}\\n\")\n",
        "\n",
        "    # -- Animation Logic --\n",
        "    start_gen_time = time.time()\n",
        "    last_check_time = time.time()\n",
        "    bar_width = 30\n",
        "\n",
        "    while True:\n",
        "        current_time = time.time()\n",
        "        elapsed = int(current_time - start_gen_time)\n",
        "        mins, secs = divmod(elapsed, 60)\n",
        "\n",
        "        # Calculate bouncing block position\n",
        "        pos = int((current_time * 15) % (bar_width * 2))\n",
        "        if pos >= bar_width:\n",
        "            pos = (bar_width * 2) - 1 - pos\n",
        "\n",
        "        bar = ['-'] * bar_width\n",
        "        bar[pos] = '█'\n",
        "        bar_str = \"\".join(bar)\n",
        "\n",
        "        sys.stdout.write(f\"\\r{C.C}🎨 Generating Masterpiece: {C.X}[{C.Y}{bar_str}{C.X}] {C.P}⏱️ {mins:02d}:{secs:02d} elapsed{C.X}\")\n",
        "        sys.stdout.flush()\n",
        "\n",
        "        # Ping server every 5 seconds\n",
        "        if current_time - last_check_time >= 5:\n",
        "            if server_process.poll() is not None:\n",
        "                print(f\"\\n\\n{C.R}❌ CRITICAL ERROR: The AI server crashed due to OOM limit.{C.X}\")\n",
        "                break\n",
        "\n",
        "            history = get_history(prompt_id)\n",
        "            if prompt_id in history:\n",
        "                print(f\"\\n\\n{C.G}✨ GENERATION COMPLETE! ✨{C.X}\\n\")\n",
        "                for node_id, node_output in history[prompt_id]['outputs'].items():\n",
        "                    if 'images' in node_output:\n",
        "                        for image in node_output['images']:\n",
        "                            img_path = os.path.join(\"output\", image.get('subfolder', ''), image['filename'])\n",
        "                            print(f\"{C.Y}💾 Saved to: {img_path}{C.X}\")\n",
        "                            display(Image(filename=img_path))\n",
        "                break\n",
        "            last_check_time = current_time\n",
        "\n",
        "        time.sleep(0.05) # Refresh frame rate\n",
        "\n",
        "except Exception as e:\n",
        "    print(f\"\\n\\n{C.R}❌ Execution Interrupted: {e}{C.X}\")\n",
        "\n",
        "finally:\n",
        "    print(f\"\\n{C.Y}🛑 Shutting down backend to free resources...{C.X}\")\n",
        "    server_process.kill()\n",
        "    log_file.close()"
      ]
    }
